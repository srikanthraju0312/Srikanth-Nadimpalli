<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600&display=swap" rel="stylesheet">

<style>
  .custom-header {
    width: 100%;
    max-width: 1440px;
    height: 64px;
    margin: 0 auto;
    padding: 10px 50px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #F7F7F7;
    box-sizing: border-box;
    font-family: 'Jost', sans-serif !important;
    transition: height 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    overflow: hidden;
  }

  .custom-header.is-open {
    height: 189px;
  }

  .custom-header__logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .custom-header__logo {
    width: 151.44px;
    height: 19px;
    object-fit: contain;
  }

  .custom-header__logo-text {
    font-size: 24px;
    font-weight: 600;
    margin: 0;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .custom-header__text {
    flex: 1;
    text-align: center;
    font-size: 16px;
    line-height: 13.42px;
    color: #000000;
    margin: 0 20px;
    white-space: nowrap;
    font-weight: 400;
  }

  .custom-header__button {
    width: 207px;
    height: 44px;
    background: #FFF544;
    color: #000000;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 400;
    line-height: 20.48px;
    text-transform: uppercase;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    overflow: hidden;
    transition: color 0.3s ease, transform 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    gap: 12px;
  }

  .custom-header__button::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 100%;
    background-color: #000000;
    transition: width 0.3s ease;
    z-index: -1;
  }

  .custom-header__button:hover {
    color: #ffffff;
    transform: scale(1.05);
  }

  .custom-header__button:hover::before {
    width: 100%;
  }

  .custom-header__arrow {
    width: 24px;
    height: auto;
    display: flex;
    align-items: center;
    transition: filter 0.3s ease;
  }

  .custom-header__button:hover .custom-header__arrow {
    filter: invert(1);
  }

  .custom-header__top-row {
    display: flex;
    align-items: center;
  }

  .custom-header__bottom-content {
    display: flex;
    align-items: center;
    flex: 1;
    justify-content: space-between;
  }

  .custom-header__hamburger {
    display: none !important;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 10px;
    background: transparent;
    border: none;
    outline: none;
    padding: 0;
    cursor: pointer;
    flex-shrink: 0;
    box-shadow: none;
  }

  .custom-header__hamburger svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .custom-header__close {
    display: none !important;
  }

  @media screen and (max-width: 768px) {
    .custom-header {
      height: 65px;
      padding: 0 16px;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      gap: 0;
    }

    .custom-header__bottom-content {
      display: none;
    }

    .custom-header__top-row {
      width: 100%;
      height: 65px;
      display: flex;
      align-items: center;
      position: relative;
    }

    .custom-header__hamburger {
      display: flex !important;
      position: absolute;
      left: 0;
      z-index: 10;
    }

    .custom-header.is-open .custom-header__hamburger {
      display: none !important;
    }

    .custom-header__close {
      display: none;
      width: 12.73px;
      height: 13px;
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
      position: relative;
      flex-shrink: 0;
    }

    .custom-header__close::before,
    .custom-header__close::after {
      content: '';
      position: absolute;
      top: 50%;
      left: 0;
      width: 100%;
      height: 2px;
      background: #000;
    }

    .custom-header__close::before {
      transform: rotate(45deg);
    }

    .custom-header__close::after {
      transform: rotate(-45deg);
    }

    .custom-header.is-open .custom-header__close {
      display: flex !important;
      position: absolute;
      left: 0;
      z-index: 10;
    }

    .custom-header__logo-link {
      flex: 1;
      display: flex;
      justify-content: center;
      transition: all 0.3s ease;
    }

    /* In closed state, move logo to left with 78px gap from hamburger */
    .custom-header:not(.is-open) .custom-header__logo-link {
      justify-content: flex-start;
      padding-left: 96px; /* 18px (hamburger) + 78px (gap) */
    }

    .custom-header__text {
      display: none;
      font-size: 16px;
      line-height: 24px;
      white-space: nowrap;
      text-align: center;
      margin: 0;
    }

    .custom-header__button {
      display: none;
      width: 100%;
      height: 44px;
      margin: 0;
    }

    .custom-header.is-open .custom-header__text,
    .custom-header.is-open .custom-header__button {
      display: flex;
    }
    
    .custom-header.is-open .custom-header__bottom-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 124px;
      padding: 25px 65.5px;
      gap: 16px;
      box-sizing: border-box;
    }
  }

  @media screen and (min-width: 769px) {
    .custom-header__top-row,
    .custom-header__bottom-content {
      display: contents;
    }
  }
</style>

<header class="custom-header">
  <div class="custom-header__top-row">
    <button class="custom-header__hamburger" aria-label="Open Menu">
      <svg width="18" height="10" viewBox="0 0 18 10" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 1H18M0 5H18M0 9H18" stroke="#000000" stroke-width="2"/>
      </svg>
    </button>
    <button class="custom-header__close" aria-label="Close Menu"></button>

    <a href="{{ routes.root_url }}" class="custom-header__logo-link">
      {%- if section.settings.logo_image != blank -%}
        {{ section.settings.logo_image | image_url: width: 400 | image_tag: class: 'custom-header__logo', alt: shop.name }}
      {%- elsif section.settings.logo_text != blank -%}
        <h1 class="custom-header__logo-text">{{ section.settings.logo_text }}</h1>
      {%- else -%}
        <img src="{{ 'tisso_vission.svg' | asset_url }}" alt="Tisso Vision" class="custom-header__logo">
      {%- endif -%}
    </a>
  </div>

  <div class="custom-header__bottom-content">
    <div class="custom-header__text">
      {{ section.settings.middle_text }}
    </div>

    <a href="{{ section.settings.button_link }}" class="custom-header__button">
      {{ section.settings.button_label }}
      <img src="{{ 'right_arrow.svg' | asset_url }}" alt="" class="custom-header__arrow">
    </a>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const header = document.querySelector('.custom-header');
    const hamburger = document.querySelector('.custom-header__hamburger');
    const closeBtn = document.querySelector('.custom-header__close');

    if (hamburger && closeBtn && header) {
      const toggleMenu = () => {
        header.classList.toggle('is-open');
      };

      hamburger.addEventListener('click', toggleMenu);
      closeBtn.addEventListener('click', toggleMenu);
    }
  });
</script>

{% schema %}
{
  "name": "Custom Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "TISSO VISION"
    },
    {
      "type": "text",
      "id": "middle_text",
      "label": "Middle Text",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ]
}
{% endschema %}
